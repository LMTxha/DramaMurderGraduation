.genre-bar {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.genre {
  flex: 0 0 auto;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #efe7dc;
  color: #615852;
  font-size: 24rpx;
}

.genre.active {
  background: #a83c32;
  color: #fff;
}

.script-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.cover {
  width: 168rpx;
  height: 224rpx;
  border-radius: 8rpx;
  background: #ded4c8;
}

.script-body {
  flex: 1;
  min-width: 0;
}

.script-title {
  font-size: 32rpx;
  font-weight: 800;
}

.summary {
  display: -webkit-box;
  margin-top: 14rpx;
  color: #4b433d;
  font-size: 25rpx;
  line-height: 1.5;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.bottom {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #a83c32;
  font-weight: 700;
}
