.search {
  display: grid;
  grid-template-columns: 1fr 132rpx;
  gap: 14rpx;
  padding: 14rpx;
}

.search-input {
  height: 70rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #f7f0e7;
  font-size: 26rpx;
}

.search-btn {
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 8rpx;
  background: #2f2923;
  color: #fffaf2;
  font-size: 26rpx;
}

.genre-scroll {
  margin: 24rpx 0 18rpx;
  white-space: nowrap;
}

.genre-track {
  display: flex;
  gap: 14rpx;
}

.genre {
  display: inline-flex;
  align-items: center;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #e9dfd3;
  color: #574b43;
  font-size: 24rpx;
}

.genre.active {
  background: #9a3d31;
  color: #fff;
}

.script {
  display: flex;
  gap: 20rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
}

.poster {
  width: 176rpx;
  height: 232rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  background: #2f2923;
  color: #fffaf2;
  text-align: center;
  font-weight: 700;
  box-sizing: border-box;
}

.script-main {
  flex: 1;
  min-width: 0;
}

.script-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.price {
  color: #9a3d31;
  font-size: 30rpx;
  font-weight: 800;
  white-space: nowrap;
}

.summary {
  display: -webkit-box;
  margin-top: 12rpx;
  color: #4b433c;
  font-size: 25rpx;
  line-height: 36rpx;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.script-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 18rpx;
}
