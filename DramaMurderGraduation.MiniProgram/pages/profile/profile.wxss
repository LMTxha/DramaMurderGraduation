.profile-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  background: #2f2923;
  color: #fffaf2;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #c8a46b;
  color: #2f2923;
  font-size: 42rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.head-title {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 800;
}

.head-sub {
  margin-top: 8rpx;
  color: rgba(255, 250, 242, 0.78);
  font-size: 24rpx;
}

.auth,
.wallet,
.recharge,
.api-card {
  margin-top: 24rpx;
  padding: 24rpx;
}

.tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-bottom: 22rpx;
  padding: 8rpx;
  border-radius: 8rpx;
  background: #efe3d5;
}

.tab {
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 8rpx;
  text-align: center;
  color: #5b5047;
  font-size: 26rpx;
}

.tab.active {
  background: #fffaf2;
  color: #9a3d31;
  font-weight: 800;
}

.input {
  margin-bottom: 18rpx;
}

.wallet {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.balance {
  margin-top: 6rpx;
  color: #9a3d31;
  font-size: 48rpx;
  font-weight: 800;
}

.record {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: 14rpx;
}

.record-amount {
  color: #9a3d31;
  font-size: 30rpx;
  font-weight: 800;
  white-space: nowrap;
}

.logout {
  margin-top: 26rpx;
}

.demo-btn {
  margin-top: 14rpx;
}
