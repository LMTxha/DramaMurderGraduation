<view class="page">
  <view class="profile-head">
    <view class="avatar">{{userInitial}}</view>
    <view class="profile-copy">
      <view class="head-title">{{user ? (user.DisplayName || user.Username) : '欢迎来到雾城剧本研究所'}}</view>
      <view class="head-sub">{{user ? (user.RoleDisplayName || '玩家') : '登录后预约、查看订单和管理钱包'}}</view>
    </view>
  </view>

  <view wx:if="{{!user}}" class="auth card">
    <view class="tabs">
      <view class="tab {{mode == 'login' ? 'active' : ''}}" data-mode="login" bindtap="switchMode">登录</view>
      <view class="tab {{mode == 'register' ? 'active' : ''}}" data-mode="register" bindtap="switchMode">注册</view>
    </view>

    <view wx:if="{{mode == 'login'}}">
      <input class="input" placeholder="用户名" value="{{login.username}}" data-field="username" bindinput="loginInput" />
      <input class="input" password placeholder="密码" value="{{login.password}}" data-field="password" bindinput="loginInput" />
      <button class="primary-btn" bindtap="doLogin">登录</button>
      <button class="plain-btn demo-btn" bindtap="demoLogin">演示登录</button>
    </view>

    <view wx:else>
      <input class="input" placeholder="用户名" value="{{register.username}}" data-field="username" bindinput="registerInput" />
      <input class="input" password placeholder="密码" value="{{register.password}}" data-field="password" bindinput="registerInput" />
      <input class="input" placeholder="昵称" value="{{register.displayName}}" data-field="displayName" bindinput="registerInput" />
      <input class="input" type="number" placeholder="手机号" value="{{register.phone}}" data-field="phone" bindinput="registerInput" />
      <input class="input" placeholder="邮箱" value="{{register.email}}" data-field="email" bindinput="registerInput" />
      <button class="primary-btn" bindtap="doRegister">提交注册</button>
    </view>
  </view>

  <view wx:else>
    <view class="wallet card">
      <view>
        <view class="caption">钱包余额</view>
        <view class="balance">￥{{user.Balance}}</view>
      </view>
      <view class="tag">{{user.ReviewStatus || 'Approved'}}</view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">充值申请</view>
      </view>
      <view class="card recharge">
        <input class="input" type="digit" placeholder="充值金额" value="{{recharge.amount}}" data-field="amount" bindinput="rechargeInput" />
        <input class="input" placeholder="支付方式" value="{{recharge.paymentMethod}}" data-field="paymentMethod" bindinput="rechargeInput" />
        <input class="input" placeholder="支付账号或备注" value="{{recharge.paymentAccount}}" data-field="paymentAccount" bindinput="rechargeInput" />
        <button class="secondary-btn" bindtap="submitRecharge">提交审核</button>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">钱包流水</view>
      </view>
      <view wx:if="{{!wallet.transactions.length}}" class="empty card">暂无钱包流水</view>
      <view wx:for="{{wallet.transactions}}" wx:key="Id" class="record card">
        <view>
          <view class="title">{{item.Summary || item.TransactionType}}</view>
          <view class="caption">{{item.TimeText}}</view>
        </view>
        <view class="record-amount">￥{{item.AmountText}}</view>
      </view>
    </view>

    <button class="plain-btn logout" bindtap="logout">退出登录</button>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">接口设置</view>
    </view>
    <view class="card api-card">
      <input class="input" placeholder="http://localhost:5090/MiniApi.aspx" value="{{apiBase}}" bindinput="setApiBase" />
      <button class="plain-btn" bindtap="saveApiBase">保存接口地址</button>
    </view>
  </view>
</view>
