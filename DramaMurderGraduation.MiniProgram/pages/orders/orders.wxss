.empty-state {
  padding: 48rpx 28rpx;
  text-align: center;
}

.empty-state .muted {
  margin: 14rpx 0 28rpx;
}

.order {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.order-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.order-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f4eadf;
}

.value {
  display: block;
  margin-top: 6rpx;
  color: #2f2923;
  font-size: 27rpx;
  font-weight: 700;
}

.order-actions,
.review-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 24rpx;
}

.reviewed {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 8rpx;
  background: #efe3d5;
  color: #776f68;
  text-align: center;
  font-size: 24rpx;
}

.after-sale-line {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  background: #fff4df;
  color: #8a5a1f;
  font-size: 24rpx;
}

.review-box {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(45, 36, 30, 0.12);
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 25rpx;
  font-weight: 700;
}

.stars {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.star {
  color: #c8beb2;
  font-size: 42rpx;
}

.star.active {
  color: #c89b38;
}

.input,
.textarea {
  margin-bottom: 16rpx;
}
