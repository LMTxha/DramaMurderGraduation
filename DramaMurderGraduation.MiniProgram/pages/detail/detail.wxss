.detail-hero {
  position: relative;
}

.hero-cover {
  width: 100%;
  height: 520rpx;
  border-radius: 8rpx;
}

.hero-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: #2f2923;
  color: #fffaf2;
  font-size: 42rpx;
  font-weight: 800;
  box-sizing: border-box;
  text-align: center;
}

.hero-panel {
  margin: -86rpx 24rpx 0;
  padding: 26rpx;
  position: relative;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 800;
}

.hero-price {
  margin-top: 18rpx;
  color: #9a3d31;
  font-size: 34rpx;
  font-weight: 800;
}

.content {
  padding: 26rpx;
  color: #3c342e;
  font-size: 27rpx;
  line-height: 42rpx;
}

.session {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.session-main {
  flex: 1;
  min-width: 0;
}

.session-btn {
  width: 132rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 8rpx;
  background: #9a3d31;
  color: #fff;
  font-size: 25rpx;
}

.character-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.character {
  padding: 22rpx;
}

.review {
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(244, 241, 234, 0.94);
  box-shadow: 0 -10rpx 26rpx rgba(49, 39, 31, 0.08);
  box-sizing: border-box;
}
