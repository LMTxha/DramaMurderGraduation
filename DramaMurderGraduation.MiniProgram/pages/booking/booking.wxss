.booking-head {
  padding: 34rpx;
  border-radius: 8rpx;
  background: #2f2923;
  color: #fffaf2;
}

.eyebrow {
  color: rgba(255, 250, 242, 0.68);
  font-size: 20rpx;
  letter-spacing: 0;
}

.head-title {
  margin-top: 14rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.head-sub {
  margin-top: 12rpx;
  color: rgba(255, 250, 242, 0.82);
  font-size: 26rpx;
  line-height: 38rpx;
}

.login-card,
.form-card {
  margin-top: 26rpx;
  padding: 26rpx;
}

.login-card .primary-btn {
  margin-top: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #40362f;
  font-size: 25rpx;
  font-weight: 700;
}

.stepper {
  display: grid;
  grid-template-columns: 82rpx 1fr 82rpx;
  gap: 12rpx;
}

.step-btn,
.step-input {
  height: 76rpx;
  border-radius: 8rpx;
  background: #efe3d5;
  text-align: center;
  font-size: 30rpx;
}

.step-btn {
  line-height: 76rpx;
  color: #2f2923;
}
