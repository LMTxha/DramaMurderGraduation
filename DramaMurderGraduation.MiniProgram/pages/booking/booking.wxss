.picker {
  min-height: 82rpx;
  line-height: 82rpx;
  padding: 0 22rpx;
  margin-bottom: 18rpx;
  border-radius: 10rpx;
  background: #fff;
  border: 1rpx solid rgba(46, 36, 30, 0.14);
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 22rpx;
  border-radius: 10rpx;
  background: #fff;
  border: 1rpx solid rgba(46, 36, 30, 0.14);
  box-sizing: border-box;
}
