page {
  min-height: 100%;
  background: #f4f1ea;
  color: #241f1b;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.page.with-bottom {
  padding-bottom: 140rpx;
}

.section {
  margin-top: 30rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.section-action {
  color: #9a3d31;
  font-size: 24rpx;
}

.card {
  background: #fffaf2;
  border: 1rpx solid rgba(44, 34, 27, 0.1);
  border-radius: 8rpx;
  box-shadow: 0 12rpx 28rpx rgba(48, 39, 32, 0.07);
  box-sizing: border-box;
}

.muted {
  color: #7c736a;
  font-size: 24rpx;
  line-height: 34rpx;
}

.title {
  color: #241f1b;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.caption {
  color: #8c8278;
  font-size: 22rpx;
  line-height: 32rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #efe3d5;
  color: #76382f;
  font-size: 22rpx;
  white-space: nowrap;
}

.tag.dark {
  background: #2d2925;
  color: #fff7ed;
}

.primary-btn,
.secondary-btn,
.plain-btn {
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-btn {
  background: #9e3b31;
  color: #fff;
}

.secondary-btn {
  background: #2c2925;
  color: #fff7ed;
}

.plain-btn {
  background: #eadfd2;
  color: #2c2621;
}

.primary-btn[disabled],
.secondary-btn[disabled] {
  background: #c9c0b6;
  color: #fff;
}

.input,
.textarea,
.picker {
  width: 100%;
  background: #fff;
  border: 1rpx solid rgba(45, 36, 30, 0.14);
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #261f1a;
  font-size: 28rpx;
}

.input,
.picker {
  height: 82rpx;
  line-height: 82rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 168rpx;
  padding: 20rpx 22rpx;
  line-height: 38rpx;
}

.empty {
  padding: 52rpx 28rpx;
  text-align: center;
  color: #7c736a;
  font-size: 26rpx;
}

.loading {
  padding: 70rpx 0;
  text-align: center;
  color: #7c736a;
  font-size: 26rpx;
}

.cover {
  background: #ded4c8;
}
