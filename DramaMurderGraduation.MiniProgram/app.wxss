page {
  background: #f5f2ec;
  color: #262220;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.card {
  background: #fffaf2;
  border: 1rpx solid rgba(46, 36, 30, 0.1);
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(37, 31, 27, 0.06);
}

.muted {
  color: #776f68;
  font-size: 24rpx;
}

.button {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 10rpx;
  background: #a83c32;
  color: #fff;
  font-size: 28rpx;
}

.ghost-button {
  background: #efe7dc;
  color: #332a25;
}

.input {
  height: 82rpx;
  padding: 0 22rpx;
  margin-bottom: 18rpx;
  border-radius: 10rpx;
  background: #fff;
  border: 1rpx solid rgba(46, 36, 30, 0.14);
  box-sizing: border-box;
}

.tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #efe7dc;
  color: #6d3a31;
  font-size: 22rpx;
}
