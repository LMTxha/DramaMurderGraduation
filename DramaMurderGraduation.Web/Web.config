<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="DramaMurderDb"
         connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=DramaMurderGraduationDb;Integrated Security=True;Connect Timeout=30;MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="DatabaseName" value="DramaMurderGraduationDb" />
    <add key="DatabaseDirectory" value="~/App_Data" />
    <add key="AiDefaultProvider" value="nvidia" />
    <add key="AiDefaultSystemPrompt" value="你是雾城剧本研究所内置的 AI 助手。回答要直接、准确、可执行，优先使用中文，适合玩家选本、门店运营、预约沟通、文案生成和问题检索场景。" />
    <add key="AiNvidiaBaseUrl" value="https://integrate.api.nvidia.com/v1" />
    <add key="AiNvidiaApiKey" value="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" />
    <add key="AiNvidiaDefaultModel" value="qwen/qwen2.5-coder-32b-instruct" />
    <add key="AiDoubaoBaseUrl" value="" />
    <add key="AiDoubaoApiKey" value="" />
    <add key="AiDoubaoDefaultModel" value="doubao-pro-32k" />
    <add key="AiKimiBaseUrl" value="https://api.moonshot.cn/v1" />
    <add key="AiKimiApiKey" value="" />
    <add key="AiKimiDefaultModel" value="moonshot-v1-8k" />
    <add key="AiQwenCnBaseUrl" value="https://dashscope.aliyuncs.com/compatible-mode/v1" />
    <add key="AiQwenCnApiKey" value="" />
    <add key="AiQwenCnDefaultModel" value="qwen-plus" />
    <add key="AiQwenIntlBaseUrl" value="https://dashscope-intl.aliyuncs.com/compatible-mode/v1" />
    <add key="AiQwenIntlApiKey" value="" />
    <add key="AiQwenIntlDefaultModel" value="qwen-plus" />
    <add key="AiQwenUsBaseUrl" value="https://dashscope-us.aliyuncs.com/compatible-mode/v1" />
    <add key="AiQwenUsApiKey" value="" />
    <add key="AiQwenUsDefaultModel" value="qwen-plus" />
    <add key="AiZhipuBaseUrl" value="https://open.bigmodel.cn/api/paas/v4/" />
    <add key="AiZhipuApiKey" value="" />
    <add key="AiZhipuDefaultModel" value="glm-4-plus" />
    <add key="AiDeepSeekBaseUrl" value="https://api.deepseek.com" />
    <add key="AiDeepSeekApiKey" value="" />
    <add key="AiDeepSeekDefaultModel" value="deepseek-chat" />
    <add key="AiTencentYuanbaoBaseUrl" value="" />
    <add key="AiTencentYuanbaoApiKey" value="" />
    <add key="AiTencentYuanbaoDefaultModel" value="hunyuan-turbos-latest" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.8.1" />
    <httpRuntime targetFramework="4.8.1" requestValidationMode="4.5" maxRequestLength="10240" />
    <pages controlRenderingCompatibilityVersion="4.0" clientIDMode="Predictable" />
    <customErrors mode="Off" />
    <globalization culture="zh-CN" uiCulture="zh-CN" requestEncoding="utf-8" responseEncoding="utf-8" fileEncoding="utf-8" />
  </system.web>
  <system.webServer>
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="Default.aspx" />
      </files>
    </defaultDocument>
    <staticContent>
      <remove fileExtension=".sql" />
      <mimeMap fileExtension=".sql" mimeType="text/plain" />
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>
  </system.webServer>
</configuration>
